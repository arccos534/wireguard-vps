# If you run this from root on the VPS, 0:0 is the simplest option.
# If you have a normal Linux user, replace these with the output of `id`.
PUID=0
PGID=0

# Example: Europe/Moscow, Asia/Vladivostok, UTC
TZ=Asia/Vladivostok

# Public IP or domain of your VPS.
# Example: 203.0.113.10 or vpn.example.com
SERVERURL=YOUR_VPS_IP

# WireGuard listens on UDP.
SERVERPORT=51820

# Peer names. These become separate client configs in ./config/peer_<name>
PEERS=phone,laptop

# DNS servers that clients will use.
PEERDNS=1.1.1.1,1.0.0.1

# Conservative mobile-friendly defaults for generated client profiles.
CLIENT_MTU=1280
CLIENT_PERSISTENTKEEPALIVE=25

# Change only if it clashes with another subnet on your server/network.
INTERNAL_SUBNET=10.13.13.0

# Route all traffic through the VPN.
ALLOWEDIPS=0.0.0.0/0

# Keep the tunnel warm for roaming/mobile clients.
PERSISTENTKEEPALIVE_PEERS=all

# Print client config QR codes to container logs on first generation.
LOG_CONFS=true
