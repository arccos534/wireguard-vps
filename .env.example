TZ=Asia/Vladivostok

# Public IP or domain clients should use.
WG_HOST=YOUR_VPS_IP

# WireGuard over UDP. 443/udp is a practical default when a website already uses 443/tcp.
WG_PORT=443

# wg-easy web UI.
UI_PORT=51821

# Host interface used for NAT.
WG_DEVICE=ens3

# DNS servers pushed to clients.
WG_DNS=1.1.1.1,1.0.0.1

# Route all client traffic through the VPN.
WG_ALLOWED_IPS=0.0.0.0/0

# Mobile-friendly MTU.
WG_MTU=1280
